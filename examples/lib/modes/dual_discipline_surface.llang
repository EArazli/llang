import "./struct_caps.llang";

doctrine DualDiscipline where {
  mode Lin classifiedBy Lin via Lin.U_Lin;
  gen comp_ctx_ext(a@Lin) : [a] -> [a] @Lin;
  gen comp_var(a@Lin) : [a] -> [a] @Lin;
  gen comp_reindex(a@Lin) : [a] -> [a] @Lin;
  comprehension Lin where { ctx_ext = comp_ctx_ext; var = comp_var; reindex = comp_reindex; };
  gen U_Lin : [] -> [Lin.U_Lin] @Lin;
  mode Cart classifiedBy Cart via Cart.U_Cart;
  gen comp_ctx_ext(a@Cart) : [a] -> [a] @Cart;
  gen comp_var(a@Cart) : [a] -> [a] @Cart;
  gen comp_reindex(a@Cart) : [a] -> [a] @Cart;
  comprehension Cart where { ctx_ext = comp_ctx_ext; var = comp_var; reindex = comp_reindex; };
  gen U_Cart : [] -> [Cart.U_Cart] @Cart;
  gen Num : [] -> [Lin.U_Lin] @Lin;
  gen Num : [] -> [Cart.U_Cart] @Cart;

  gen one : [] -> [Lin.Num] @Lin;
  gen sink : [Lin.Num, Lin.Num] -> [] @Lin;

  gen one : [] -> [Cart.Num] @Cart;
  gen sink : [Cart.Num, Cart.Num] -> [] @Cart;
  gen dup (a@Cart) : [a] -> [a, a] @Cart;
  gen drop (a@Cart) : [a] -> [] @Cart;

  rule structural coassoc_cart = (a@Cart) : [a] -> [a, a, a] @Cart =
    dup ; (dup * id[a]) == dup ; (id[a] * dup)

  rule structural counitL_cart = (a@Cart) : [a] -> [a] @Cart =
    dup ; (drop * id[a]) == id[a]

  rule structural counitR_cart = (a@Cart) : [a] -> [a] @Cart =
    dup ; (id[a] * drop) == id[a]
}

morphism cartDupInst : HasDup -> DualDiscipline where {
  mode M -> Cart;
  gen comp_ctx_ext @M -> comp_ctx_ext
  gen comp_var @M -> comp_var
  gen comp_reindex @M -> comp_reindex
  gen dup @M -> dup
  check none;
}

implements HasDup for DualDiscipline using cartDupInst;

morphism cartDropInst : HasDrop -> DualDiscipline where {
  mode M -> Cart;
  gen comp_ctx_ext @M -> comp_ctx_ext
  gen comp_var @M -> comp_var
  gen comp_reindex @M -> comp_reindex
  gen drop @M -> drop
  check none;
}

implements HasDrop for DualDiscipline using cartDropInst;
