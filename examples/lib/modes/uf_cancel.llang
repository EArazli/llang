doctrine UFCancel where {
  mode A classifiedBy A via A.U_A;
  type U_A @A;
  mode B classifiedBy B via B.U_B;
  type U_B @B;
  modality F : A -> B;
  modality U : B -> A;
  mod_eq U.F -> id@A;

  type Base @A;

  gen foo : [U(F(A.Base))] -> [U(F(A.Base))] @A;

  rule computational foo_id -> : [Base] -> [Base] @A =
    foo == id[Base]
}

term demo where {
  doctrine UFCancel;
  mode A;
}
---
foo
