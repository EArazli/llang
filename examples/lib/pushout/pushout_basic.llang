doctrine Base where {
  mode M classifiedBy M via M.U_M;
  gen U_M : [] -> [M.U_M] @M;
  gen A : [] -> [M.U_M] @M;
  gen f : [A] -> [A] @M;
}

doctrine Left extends Base where {
  gen g : [A] -> [A] @M;
  gen extra : [A] -> [A] @M;
}

doctrine Right extends Base where {
  gen g : [A] -> [A] @M;
  gen extra : [A] -> [A] @M;
}

doctrine Both = pushout Left.fromBase Right.fromBase;
