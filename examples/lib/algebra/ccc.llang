include "../../../stdlib/struct.cartesian.llang";

-- Minimal CCC fragment kept for tiny eval-focused examples.
-- For a fuller CCC/STLC-oriented axiomatization, see:
--   examples/lib/surfaces/ccc_surface/ccc.llang
doctrine CCC extends StructCartesian where {
  gen A : [] -> [U_M] @M;
  gen B : [] -> [U_M] @M;

  gen eval : [A, B] -> [A] @M;
}
