include "../../lib/pushout/nat_bool.llang";

module_surface NatBoolRunUnit where {
  doctrine NatBool;
  mode M;
}

language NatBoolRunLang where {
  doctrine NatBool;
  module_surface NatBoolRunUnit;
}

module NatBoolRuns in NatBoolRunLang where {
  let main
  ---
  (Nat_inl_Z * (Nat_inl_Z ; Nat_inl_S)) ; Nat_inl_add
  ---
  export { main };
}

pipeline debug where {
  project export main;
  normalize { policy = "topmost"; fuel = 50; };
}

build main from NatBoolRuns using debug;
