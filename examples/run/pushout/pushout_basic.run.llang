include "../../lib/pushout/pushout_basic.llang";

module_surface PushoutBasicRunUnit where {
  doctrine Both;
  mode M;
}

language PushoutBasicRunLang where {
  doctrine Both;
  module_surface PushoutBasicRunUnit;
}

module PushoutBasicRuns in PushoutBasicRunLang where {
  let main
  ---
  Left_inl_g ; Right_inr_g
  ---
  export { main };
}

pipeline main where {
  project export main;
  normalize;
}

build main from PushoutBasicRuns using main;
