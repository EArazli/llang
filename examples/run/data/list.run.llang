include "../../../stdlib/data/list.llang";

doctrine ListWithA extends ListData where {
  gen A : [] -> [U_M] @M;
}

module_surface ListRunUnit where {
  doctrine ListWithA;
  mode M;
}

language ListRunLang where {
  doctrine ListWithA;
  module_surface ListRunUnit;
}

module ListRuns in ListRunLang where {
  let main
  ---
  Nil(A)
  ---
  export { main };
}

pipeline main where {
  project export main;
  normalize;
}

build main from ListRuns using main;
