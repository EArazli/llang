include "../../../stdlib/data/list.llang";

doctrine NatList extends ListData where {
  data Nat @M where {
    Zero : [];
    Succ : [Nat];
  }

  gen A : [] -> [U_M] @M;
  gen drop(a@M) : [a] -> [] @M;
  gen a : [] -> [A] @M;
  gen b : [] -> [A] @M;
}

module_surface ListFoldRunUnit where {
  doctrine NatList;
  mode M;
}

language ListFoldRunLang where {
  doctrine NatList;
  module_surface ListFoldRunUnit;
}

module ListFoldRuns in ListFoldRunLang where {
  let main
  ---
  a * (b * Nil(A) ; Cons(A)) ; Cons(A) ; fold_List(A, Nat)[Zero, drop(A) * id[Nat] ; Succ]
  ---
  export { main };
}

pipeline main where {
  project export main;
  normalize { policy = "computational_lr"; fuel = 50; };
}

build main from ListFoldRuns using main;
