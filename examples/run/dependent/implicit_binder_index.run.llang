doctrine ImplicitBinderIndex where {
  mode M classifiedBy M via M.U_M;
  type U_M @M;
  mode I classifiedBy I via I.U_I;
  type U_I @I;
  type Nat @I;
  gen Z : [] -> [Nat] @I;

  type Vec(n : Nat) @M;
  type Out @M;

  gen use(n : Nat) : [] -> [Vec(n)] @M;
  gen wrap : [binder { tm n : Nat } : [Vec(n)]] -> [Out] @M;
}

pipeline main where {
  normalize;
  extract diagram;
}

run main using main where {
  source doctrine ImplicitBinderIndex;
  source mode M;
}
---
wrap[use{n}]
---
