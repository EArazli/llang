include "../../lib/dependent/vec.llang";

module_surface VecRunUnit where {
  doctrine VecDependent;
  mode M;
}

language VecRunLang where {
  doctrine VecDependent;
  module_surface VecRunUnit;
}

module VecRuns in VecRunLang where {
  let main
  ---
  mk22(A) ; expect22(A)
  ---
  export { main };
}

pipeline debug where {
  project export main;
  normalize { policy = "topmost"; fuel = 50; };
}

build main from VecRuns using debug;
