doctrine ClassificationWrongClassifier where {
  mode Ty classifiedBy Ty via Ty.U_Ty;
  gen U_Ty : [] -> [Ty.U_Ty] @Ty;
  mode Tm classifiedBy Ty via Ty.U;

  gen U : [] -> [Ty.U_Ty] @Ty;
  gen Unit : [] -> [Ty.U] @Ty;
  gen Arr(a@Tm, b@Tm) : [] -> [Ty.U] @Ty;

  gen bad : [Tm.Arr(Unit, Unit)] -> [Tm.Arr(Unit, Unit)] @Tm;
}
