doctrine FreeIndexMustFail where {
  mode M classifiedBy M via M.U_M;
  type U_M @M;
  mode I classifiedBy I via I.U_I;
  type U_I @I;
  type Nat @I;
  gen Z : [] -> [Nat] @I;

  type Vec(n : Nat) @M;

  gen make(n : Nat) : [] -> [Vec(n)] @M;
}

pipeline main where {
  normalize;
  extract diagram;
}

run main using main where {
  source doctrine FreeIndexMustFail;
  source mode M;
}
---
make
---
