include "../../lib/algebra/cart_monoid.llang";

module_surface CartMonoidRunUnit where {
  doctrine CartMonoid;
  mode M;
}

language CartMonoidRunLang where {
  doctrine CartMonoid;
  module_surface CartMonoidRunUnit;
}

module CartMonoidRuns in CartMonoidRunLang where {
  let main
  ---
  dup(A) ; mul
  ---
  export { main };
}

pipeline main where {
  project export main;
  normalize;
}

build main from CartMonoidRuns using main;
