include "../../lib/algebra/box_match.llang";

module_surface BoxMatchRunUnit where {
  doctrine BoxMatch;
  mode M;
}

language BoxMatchRunLang where {
  doctrine BoxMatch;
  module_surface BoxMatchRunUnit;
}

module BoxMatchRuns in BoxMatchRunLang where {
  let main
  ---
  box B { g }
  ---
  export { main };
}

pipeline main where {
  project export main;
  normalize;
}

build main from BoxMatchRuns using main;
