doctrine D where {
  mode C classifiedBy C via C.U_C;
  type U_C @C;
  mode V classifiedBy V via V.U_V;
  type U_V @V;
  type A @C;
  type B @V;

  gen f : [A] -> [A] @C;
  gen g : [B] -> [B] @V;
}

morphism CtoV : D -> D where {
  mode C -> V;
  mode V -> V;
  type A @C -> B @V;
  gen f @C -> g
  gen g @V -> g
}

pipeline main where {
  normalize;
  apply CtoV;
  extract diagram;
}

run main using main where {
  source doctrine D;
  source mode C;
}
---
f
---
