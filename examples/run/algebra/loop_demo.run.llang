include "../../lib/algebra/loop_demo.llang";

module_surface LoopDemoRunUnit where {
  doctrine LoopDemo;
  mode M;
}

language LoopDemoRunLang where {
  doctrine LoopDemo;
  module_surface LoopDemoRunUnit;
}

module LoopDemoRuns in LoopDemoRunLang where {
  let main
  ---
  loop { dup ; (id[A] * f) }
  ---
  export { main };
}

pipeline main where {
  project export main;
  normalize;
}

build main from LoopDemoRuns using main;
