include "../../lib/algebra/coherence_demo.llang";

module_surface CoherenceDemoRunUnit where {
  doctrine CoherenceDemo;
  mode M;
}

language CoherenceDemoRunLang where {
  doctrine CoherenceDemo;
  module_surface CoherenceDemoRunUnit;
}

module CoherenceDemoRuns in CoherenceDemoRunLang where {
  let main
  ---
  f
  ---
  export { main };
}

pipeline main where {
  project export main;
  normalize { policy = "all_oriented"; };
}

build main from CoherenceDemoRuns using main;
