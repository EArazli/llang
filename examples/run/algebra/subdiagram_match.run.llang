include "../../lib/algebra/subdiagram_match.llang";

module_surface SubdiagramRunUnit where {
  doctrine Subdiagram;
  mode M;
}

language SubdiagramRunLang where {
  doctrine Subdiagram;
  module_surface SubdiagramRunUnit;
}

module SubdiagramRuns in SubdiagramRunLang where {
  let main
  ---
  h ; f ; g ; h
  ---
  export { main };
}

pipeline debug where {
  project export main;
  normalize { policy = "topmost"; fuel = 50; };
}

build main from SubdiagramRuns using debug;
