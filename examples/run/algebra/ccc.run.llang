import "../../lib/surfaces/ccc_surface/ccc.llang";

pipeline debug where {
  normalize { policy = "computational_lr"; fuel = 200; };
  extract diagram;
}

run beta_app using debug where {
  source doctrine CCC;
  source mode M;
}
---
(
  eval(Obj, Obj)
  *
  (
    (curry(Obj, Obj, Obj) * id[Hom(Obj, Obj)])
    ; pair(exp(Obj, Obj), Obj, Obj)
  )
) ; comp(Obj, prod(exp(Obj, Obj), Obj), Obj)
---
