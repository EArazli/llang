include "../../lib/algebra/ski.llang";

module_surface SkiRunUnit where {
  doctrine SKI;
  mode M;
}

language SkiRunLang where {
  doctrine SKI;
  module_surface SkiRunUnit;
}

module SkiRuns in SkiRunLang where {
  let main
  ---
  (i * id[T]) ; app
  ---
  export { main };
}

pipeline main where {
  project export main;
  normalize;
}

build main from SkiRuns using main;
