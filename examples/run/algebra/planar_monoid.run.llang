import "../../lib/algebra/planar_monoid.llang";

pipeline main where {
  normalize;
  extract diagram;
}

run main using main where {
  source doctrine PlanarMonoid;
}
---
(unit * unit) ; mul
---

run assoc_unit using main where {
  source doctrine PlanarMonoid;
}
---
(unit * (unit * unit)) ; (id[A] * mul) ; mul
---
