doctrine Invol where {
  mode M classifiedBy M via M.U_M;
  gen U_M : [] -> [M.U_M] @M;
  gen A : [] -> [M.U_M] @M;
  gen f : [A] -> [A] @M;
  rule computational inv -> : [A] -> [A] @M =
    f ; f == id[A]
}

morphism Double : Invol -> Invol where {
  gen f @ M -> f ; f
}

pipeline main where {
  normalize;
  apply Double;
  extract diagram;
}

run main using main where {
  source doctrine Invol;
  source mode M;
}
---
f
