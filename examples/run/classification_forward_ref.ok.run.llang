doctrine ClassificationForwardRef where {
  mode Tm classifiedBy Ty via Ty.U;
  mode Ty classifiedBy Ty via Ty.U_Ty;
  type U_Ty @Ty;
  type U @Ty;
  type Unit @Ty;
  type Arr(a@Tm, b@Tm) @Ty;

  gen idArr : [Arr(Unit, Unit)] -> [Arr(Unit, Unit)] @Tm;
}

pipeline main where {
  normalize;
  extract diagram;
}

run main using main where {
  source doctrine ClassificationForwardRef;
  source mode Tm;
}
---
idArr
---
