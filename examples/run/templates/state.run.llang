include "../../lib/templates/state.template.llang";

module_surface StateRunUnit where {
  doctrine StateNat;
  mode M;
}

language StateRunLang where {
  doctrine StateNat;
  module_surface StateRunUnit;
}

module StateRuns in StateRunLang where {
  let main
  ---
  get
  ---
  export { main };
}

pipeline main where {
  project export main;
  normalize;
}

build main from StateRuns using main;
